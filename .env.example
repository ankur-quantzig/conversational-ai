OPENAI_API_KEY=your_openai_api_key
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_document_intelligence_key
APP_ENV=local
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://localhost:8080

# Optional overrides
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_ANSWER_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4.1-mini
QUALITY_ENRICHMENT_PROVIDER=heuristic
QUALITY_ENRICHMENT_MODEL=
QUALITY_ENRICHMENT_REQUIRED=false
QUALITY_MIN_LLM_CHARS=80
RETRIEVAL_TOP_K=4
RATE_LIMIT_PER_MINUTE=30
BASIC_USER_QUESTION_LIMIT=10
POWER_USERS=ankurkumarj@quantzig.com
BASIC_USERS=surajc@quantzig.com,sidhus@quantzig.com,akshatameemamshi@quantzig.com,vikasgoyal@quantzig.com,saiprasad@quantzig.com

# Optional guardrail LLM classifier. Deterministic guardrails run even when this is empty.
# OPENAI_GUARDRAIL_MODEL=gpt-4.1-mini
GUARDRAIL_CONFIDENCE_THRESHOLD=0.9

# Optional: local-dev identity shown in the UI (greeting, user badge).
# When APP_ENV=local and no APP_API_KEYS are set, the app falls back to the
# machine's logged-in OS user. Set these to override with a specific identity.
# LOCAL_DEV_EMAIL=you@example.com
# LOCAL_DEV_NAME=Your Name

# Optional API-key auth. Leave empty only for local dev admin mode.
# Required when APP_ENV is production/staging.
# Use strong random keys; these labels are examples, not secrets.
# APP_API_KEYS={"replace-ankur-key":{"user_id":"ankurkumarj@quantzig.com","email":"ankurkumarj@quantzig.com","name":"Ankur Kumar","tenant_id":"default","roles":["analyst","power_user"],"document_ids":["*"]},"replace-suraj-key":{"user_id":"surajc@quantzig.com","email":"surajc@quantzig.com","tenant_id":"default","roles":["analyst","basic_user"],"document_ids":["*"]}}

# Local/Docker PostgreSQL. Change these values before deployment.
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change_me_locally

# Optional full URL override for non-Docker local FastAPI.
# DATABASE_URL=postgresql://user:password@localhost:5432/chatbot

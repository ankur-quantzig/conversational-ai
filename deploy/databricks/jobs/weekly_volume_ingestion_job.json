{
  "name": "insight-copilot-weekly-volume-ingestion",
  "tags": {
    "app": "insight-copilot",
    "owner": "engine",
    "purpose": "incremental-volume-ingestion"
  },
  "run_as": {
    "service_principal_name": "7344d97b-7dcf-48b5-9cd2-905310a5d29e"
  },
  "schedule": {
    "quartz_cron_expression": "0 0 2 ? * SUN *",
    "timezone_id": "Asia/Kolkata",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "incremental_volume_ingestion",
      "description": "Scan Databricks Volume for new or updated documents/videos, extract OCR/audio/frames, enrich quality, embed, and rebuild LanceDB.",
      "spark_python_task": {
        "python_file": "/Workspace/Shared/insight-copilot/engine/app/pipelines/databricks_volume_ingest.py",
        "source": "WORKSPACE",
        "parameters": [
          "--input-volume",
          "/Volumes/insight-copilot/bronze/shell-bronze-insight-copilot/new_data",
          "--output-root",
          "/Volumes/insight-copilot/bronze/shell-bronze-insight-copilot/_insight_copilot_output",
          "--secret-scope",
          "insight-copilot",
          "--databricks-models-only",
          "--pdf-vision-provider",
          "databricks",
          "--frame-interval-seconds",
          "30",
          "--chunk-window-seconds",
          "60",
          "--video-transcription-provider",
          "databricks",
          "--audio-segment-seconds",
          "600",
          "--video-vision-provider",
          "databricks",
          "--video-vision-model",
          "databricks-gemini-3-5-flash",
          "--ocr-workers",
          "2",
          "--vision-workers",
          "1",
          "--vision-timeout-seconds",
          "120",
          "--quality-provider",
          "databricks",
          "--quality-model",
          "databricks-claude-sonnet-4",
          "--quality-required",
          "--enable-medallion",
          "--medallion-required",
          "--medallion-catalog",
          "insight-copilot",
          "--medallion-bronze-schema",
          "bronze",
          "--medallion-silver-schema",
          "silver",
          "--medallion-gold-schema",
          "gold"
        ]
      },
      "environment_key": "serverless_python",
      "timeout_seconds": 21600,
      "max_retries": 1,
      "min_retry_interval_millis": 900000
    }
  ],
  "environments": [
    {
      "environment_key": "serverless_python",
      "spec": {
        "client": "2",
        "dependencies": [
          "azure-ai-documentintelligence==1.0.2",
          "azure-core==1.41.0",
          "imageio-ffmpeg==0.6.0",
          "lancedb==0.33.0",
          "numpy==1.26.4",
          "openai==2.44.0",
          "pandas==2.2.2",
          "pillow==12.0.0",
          "pyarrow==16.1.0",
          "PyMuPDF==1.28.0",
          "pydantic==2.12.5",
          "python-dotenv==1.2.2"
        ]
      }
    }
  ]
}
